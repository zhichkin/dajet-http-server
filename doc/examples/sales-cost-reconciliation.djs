-- ========================================================================
-- Пример DaJet Script: сверка себестоимости продаж за период.
--
-- Задача: сверить две независимо считаемые величины себестоимости за
-- полуинтервал [@НачалоПериода, @КонецПериода):
--   (1) сумму ресурса "Себестоимость" по двум регистрам накопления
--       (основная реализация + корректировка);
--   (2) дебетовый оборот счёта учёта себестоимости (90.02) по регистру
--       бухгалтерии.
-- JOIN к плану счетов нужен, чтобы отобрать проводки по счёту по его КОДУ
-- (а не по ссылке, которая в каждой базе своя).
-- Возвращаются обе суммы; расхождение = их разность (считается на стороне
-- вызывающего, либо вынесите третьей колонкой выражением colA - colB).
--
-- Имена объектов — иллюстративные (стиль 1С:Бухгалтерия); подставьте свои.
-- ========================================================================

DECLARE @НачалоПериода datetime
DECLARE @КонецПериода  datetime
DECLARE @Результат     array

USE 'BUH'   -- зарегистрированная на сервере база (имя источника данных)

  SELECT
      (SELECT ISNULL(SUM(Себестоимость), 0)
         FROM РегистрНакопления.СебестоимостьПродаж
        WHERE Активность = TRUE
          AND Период >= @НачалоПериода AND Период < @КонецПериода)
    + (SELECT ISNULL(SUM(Себестоимость), 0)
         FROM РегистрНакопления.КорректировкаСебестоимости
        WHERE Активность = TRUE
          AND Период >= @НачалоПериода AND Период < @КонецПериода)
        AS РегистрСебестоимость,
      (SELECT ISNULL(SUM(r.Сумма), 0)
         FROM РегистрБухгалтерии.Хозрасчетный AS r
        INNER JOIN ПланСчетов.Хозрасчетный AS acc ON r.СчетДт = acc.Ссылка
        WHERE r.Активность = TRUE
          AND r.Период >= @НачалоПериода AND r.Период < @КонецПериода
          AND acc.Код LIKE '90.02%')
        AS СчетСебестоимостиДебет
    INTO @Результат

END

RETURN @Результат
